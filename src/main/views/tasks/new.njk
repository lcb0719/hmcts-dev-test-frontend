{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/select/macro.njk" import govukSelect %}

{% extends "template.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Create a task</h1>

      {% if error %}
        <div class="govuk-error-summary" role="alert" aria-labelledby="error-summary-title" tabindex="-1">
          <h2 class="govuk-error-summary__title" id="error-summary-title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <p class="govuk-body">{{ error }}</p>
          </div>
        </div>
      {% endif %}

      {% if fieldErrors %}
        <div class="govuk-error-summary" role="alert" aria-labelledby="field-error-summary-title" tabindex="-1">
          <h2 class="govuk-error-summary__title" id="field-error-summary-title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              {% for field, message in fieldErrors %}
                <li><a href="#{{ field }}">{{ message }}</a></li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}

      <form method="post" action="/tasks" novalidate>
        {{ govukInput({
          label: { text: "Title" },
          id: "title",
          name: "title",
          value: form.title,
          errorMessage: { text: fieldErrors.title } if fieldErrors and fieldErrors.title
        }) }}

        {{ govukTextarea({
          label: { text: "Description (optional)" },
          id: "description",
          name: "description",
          value: form.description
        }) }}

        {{ govukSelect({
          id: "status",
          name: "status",
          label: { text: "Status" },
          items: statuses,
          value: form.status,
          errorMessage: { text: fieldErrors.status } if fieldErrors and fieldErrors.status
        }) }}

        {{ govukInput({
          label: { text: "Due date and time" },
          id: "dueDateTime",
          name: "dueDateTime",
          type: "datetime-local",
          value: form.dueDateTime,
          errorMessage: { text: fieldErrors.dueDateTime } if fieldErrors and fieldErrors.dueDateTime
        }) }}

        {{ govukButton({ text: "Create task" }) }}
        <a href="/tasks" class="govuk-link govuk-!-margin-left-3">Cancel</a>
      </form>
    </div>
  </div>
{% endblock %}

{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}

{% extends "template.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">{{ task.title }}</h1>

      {% if created %}
        {{ govukNotificationBanner({
          type: "success",
          titleText: "Success",
          html: "Task created."
        }) }}
      {% endif %}

      {% if updated %}
        {{ govukNotificationBanner({
          type: "success",
          titleText: "Success",
          html: "Task status updated."
        }) }}
      {% endif %}

      {{ govukSummaryList({
        rows: [
          {
            key: { text: "Status" },
            value: { html: '<strong class="govuk-tag ' + task.statusTagClass + '">' + task.statusLabel + '</strong>' }
          },
          {
            key: { text: "Due" },
            value: { text: task.dueDateFormatted }
          },
          {
            key: { text: "Description" },
            value: { text: task.description if task.description else "—" }
          }
        ]
      }) }}

      <div class="govuk-button-group">
        {{ govukButton({
          text: "Update status",
          href: "/tasks/" + task.id + "/edit-status"
        }) }}
        <a href="/tasks" class="govuk-link">Back to tasks</a>
      </div>

      <form method="post" action="/tasks/{{ task.id }}/delete" class="govuk-!-margin-top-6">
        {{ govukButton({
          text: "Delete task",
          name: "delete",
          classes: "govuk-button--warning"
        }) }}
      </form>
    </div>
  </div>
{% endblock %}
